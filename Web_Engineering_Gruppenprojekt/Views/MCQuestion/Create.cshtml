@using Web_Engineering_Gruppenprojekt.Models.ViewModels
@model QuestionEditViewModel
@{
    var chapter = ViewBag.Chapter as Web_Engineering_Gruppenprojekt.Models.Chapter;
    ViewData["Title"] = "Frage erstellen";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Index">Lehrveranstaltungen</a></li>
        <li class="breadcrumb-item"><a asp-controller="Chapter" asp-action="Index" asp-route-courseId="@chapter?.CourseId">@chapter?.Course?.Title</a></li>
        <li class="breadcrumb-item"><a asp-action="Index" asp-route-chapterId="@Model.ChapterId">@chapter?.Title</a></li>
        <li class="breadcrumb-item active">Frage erstellen</li>
    </ol>
</nav>

<h2>Frage erstellen</h2>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" method="post" asp-antiforgery="false">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ChapterId" />

            <div class="mb-3">
                <label asp-for="QuestionText" class="form-label">Fragetext</label>
                <textarea asp-for="QuestionText" class="form-control" rows="3"></textarea>
                <span asp-validation-for="QuestionText" class="text-danger"></span>
            </div>

            <p class="fw-semibold">Antwortoptionen (Richtige Antwort auswählen):</p>

            @for (int i = 1; i <= 4; i++)
            {
                <div class="input-group mb-2">
                    <div class="input-group-text">
                        <input class="form-check-input" type="radio" name="CorrectOption" value="@i"
                               @(Model.CorrectOption == i ? "checked" : "") />
                    </div>
                    @{
                        var propName = $"Option{i}";
                        var propValue = i switch { 1 => Model.Option1, 2 => Model.Option2, 3 => Model.Option3, _ => Model.Option4 };
                    }
                    <input type="text" name="@propName" value="@propValue" class="form-control" placeholder="Option @i" required />
                </div>
            }

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary">Frage erstellen</button>
                <a asp-action="Index" asp-route-chapterId="@Model.ChapterId" class="btn btn-outline-secondary">Abbrechen</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
