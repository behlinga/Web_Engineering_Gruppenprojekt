@model Web_Engineering_Gruppenprojekt.Models.ViewModels.ExamCreateViewModel
@{
    ViewData["Title"] = "Neue Prüfung";
    int totalQuestions = ViewBag.TotalQuestions ?? 0;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Index">Lehrveranstaltungen</a></li>
        <li class="breadcrumb-item"><a asp-controller="Exam" asp-action="Index" asp-route-courseId="@Model.CourseId">@Model.CourseTitle</a></li>
        <li class="breadcrumb-item active">Neue Prüfung</li>
    </ol>
</nav>

<h2>Neue Prüfung – @Model.CourseTitle</h2>

<div class="row">
    <div class="col-md-5">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="CourseId" />
            <input type="hidden" asp-for="CourseTitle" />

            <div class="mb-3">
                <label asp-for="Date" class="form-label">Prüfungsdatum</label>
                <input asp-for="Date" class="form-control" type="date" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NumberOfQuestions" class="form-label">
                    Anzahl der Fragen
                    <span class="text-muted small">(max. @totalQuestions verfügbar)</span>
                </label>
                <input asp-for="NumberOfQuestions" class="form-control" type="number" min="1" max="@totalQuestions" />
                <span asp-validation-for="NumberOfQuestions" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" @(totalQuestions == 0 ? "disabled" : "")>
                    Prüfung erstellen
                </button>
                <a asp-action="Index" asp-route-courseId="@Model.CourseId" class="btn btn-outline-secondary">Abbrechen</a>
            </div>

            @if (totalQuestions == 0)
            {
                <div class="alert alert-warning mt-3">
                    Keine Fragen in dieser Lehrveranstaltung verfügbar. Bitte zuerst Fragen hinzufügen.
                </div>
            }
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
