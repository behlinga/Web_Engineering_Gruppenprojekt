@model IEnumerable<Web_Engineering_Gruppenprojekt.Models.Course>
@using Web_Engineering_Gruppenprojekt.Models
@{
    ViewData["Title"] = "Lehrveranstaltungen";
    var chapterCounts = ViewBag.ChapterCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
    var examCounts = ViewBag.ExamCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Lehrveranstaltungen</h2>
    <a asp-action="Create" class="btn btn-primary">+ Neue Lehrveranstaltung</a>
</div>

<table class="table table-hover">
    <thead class="table-light">
    <tr>
        <th>Titel</th>
        <th>Dozent/in</th>
        <th>Niveau</th>
        <th>Kapitel</th>
        <th>Prüfungen</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var course in Model)
    {
        <tr>
            <td>
                <a asp-controller="Chapter" asp-action="Index" asp-route-courseId="@course.Id" class="fw-bold text-decoration-none">
                    @course.Title
                </a>
            </td>
            <td>@course.LecturerName</td>
            <td>
                <span class="badge @(course.Level == CourseLevel.Master ? "bg-warning text-dark" : "bg-info text-dark")">
                    @course.Level
                </span>
            </td>
            <td>
                <a asp-controller="Chapter" asp-action="Index" asp-route-courseId="@course.Id" class="badge bg-secondary text-decoration-none">
                    @(chapterCounts.TryGetValue(course.Id, out var cc) ? cc : 0) Kapitel
                </a>
            </td>
            <td>
                <a asp-controller="Exam" asp-action="Index" asp-route-courseId="@course.Id" class="badge bg-secondary text-decoration-none">
                    @(examCounts.TryGetValue(course.Id, out var ec) ? ec : 0) Prüfungen
                </a>
            </td>
            <td class="text-end">
                <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-sm btn-outline-secondary">Bearbeiten</a>
                <a asp-action="Delete" asp-route-id="@course.Id" class="btn btn-sm btn-outline-danger">Löschen</a>
            </td>
        </tr>
    }
    </tbody>
</table>
