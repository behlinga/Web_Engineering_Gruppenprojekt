@model Web_Engineering_Gruppenprojekt.Models.Course
@{
    ViewData["Title"] = "Lehrveranstaltung löschen";
}

<h2>Lehrveranstaltung löschen</h2>

<div class="alert alert-warning">
    Soll diese Lehrveranstaltung wirklich gelöscht werden? Folgende Daten werden ebenfalls unwiderruflich gelöscht:
    <ul class="mb-0 mt-1">
        <li><strong>@Model.Chapters.Count Kapitel</strong></li>
        <li><strong>@(ViewBag.QuestionCount) Frage(n)</strong></li>
        <li><strong>@Model.Exams.Count Prüfung(en)</strong></li>
    </ul>
</div>

<dl class="row">
    <dt class="col-sm-3">Titel</dt>
    <dd class="col-sm-9">@Model.Title</dd>

    <dt class="col-sm-3">Dozent/in</dt>
    <dd class="col-sm-9">@Model.LecturerName</dd>

    <dt class="col-sm-3">Niveau</dt>
    <dd class="col-sm-9">@Model.Level</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Löschen</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Abbrechen</a>
    </div>
</form>
