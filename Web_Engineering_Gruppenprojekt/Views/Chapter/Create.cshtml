@model Web_Engineering_Gruppenprojekt.Models.Chapter
@{
    var course = ViewBag.Course as Web_Engineering_Gruppenprojekt.Models.Course;
    ViewData["Title"] = "Kapitel erstellen";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Index">Lehrveranstaltungen</a></li>
        <li class="breadcrumb-item"><a asp-action="Index" asp-route-courseId="@Model.CourseId">@course?.Title</a></li>
        <li class="breadcrumb-item active">Neues Kapitel</li>
    </ol>
</nav>

<h2>Neues Kapitel</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" enctype="multipart/form-data" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="CourseId" />

            <div class="mb-3">
                <label asp-for="ChapterNumber" class="form-label">Kapitelnummer</label>
                <input asp-for="ChapterNumber" class="form-control" type="number" />
                <span asp-validation-for="ChapterNumber" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label">Titel</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Folien (PDF)</label>
                <input type="file" name="slideFile" accept=".pdf" class="form-control" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Erstellen</button>
                <a asp-action="Index" asp-route-courseId="@Model.CourseId" class="btn btn-outline-secondary">Abbrechen</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
