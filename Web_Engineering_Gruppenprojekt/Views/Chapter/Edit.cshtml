@model Web_Engineering_Gruppenprojekt.Models.Chapter
@inject Web_Engineering_Gruppenprojekt.Services.IFileStorageService FileStorage
@{
    var course = ViewBag.Course as Web_Engineering_Gruppenprojekt.Models.Course;
    ViewData["Title"] = "Kapitel bearbeiten";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Index">Lehrveranstaltungen</a></li>
        <li class="breadcrumb-item"><a asp-action="Index" asp-route-courseId="@Model.CourseId">@course?.Title</a></li>
        <li class="breadcrumb-item active">Kapitel bearbeiten</li>
    </ol>
</nav>

<h2>Kapitel bearbeiten</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CourseId" />

            <div class="mb-3">
                <label asp-for="ChapterNumber" class="form-label">Kapitelnummer</label>
                <input asp-for="ChapterNumber" class="form-control" type="number" min="1" />
                <span asp-validation-for="ChapterNumber" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label">Titel</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Folien (PDF)</label>
                @if (!string.IsNullOrEmpty(Model.SlidePath))
                {
                    <div class="mb-2">
                        <span class="badge bg-success me-2">@Model.SlideFileName</span>
                        <a href="@FileStorage.GetUrl(Model.SlidePath)" target="_blank" class="small">Öffnen</a>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" name="deleteFile" id="deleteFile" value="true" />
                        <label class="form-check-label text-danger" for="deleteFile">Datei löschen</label>
                    </div>
                }
                else
                {
                    <input type="file" name="slideFile" accept=".pdf" class="form-control" />
                }
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Speichern</button>
                <a asp-action="Index" asp-route-courseId="@Model.CourseId" class="btn btn-outline-secondary">Abbrechen</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
